graph LR
    %% 节点定义
    CC-26[CC-26: 社团赛事主页]
    CC-15[CC-15: 成员加入弹窗]
    CC-7[CC-7: 投稿表单]
    CC-31[CC-31: S端后管审核开关]

    %% 流程逻辑
    CC-26 -- "点击[我要参赛]" --> Check{身份校验}
    
    Check -- "非社员" --> CC-15
    CC-15 -- "点击[加入战队/社团]" --> Act1[系统: 一键入社]
    Act1 --> CC-7
    
    Check -- "已是社员" --> CC-7
    
    CC-7 -- "提交作品" --> CC-31
    
    CC-31 -- "审核模式: OFF" --> CC-26_Fast[CC-26: 作品实时展示]
    CC-31 -- "审核模式: ON" --> CC-26_Wait[CC-26: 投稿成功/进入待审]

    %% 样式美化
    style CC-31 stroke-dasharray: 5 5
